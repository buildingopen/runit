{
  "name": "runtime-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Runtime AI - Run any FastAPI app in the cloud with zero infrastructure",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "cleanup": "tsx infra/scripts/retention-cleanup.ts",
    "cleanup:dry-run": "tsx infra/scripts/retention-cleanup.ts --dry-run"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@next/eslint-plugin-next": "^16.1.6",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.1.0",
    "turbo": "^2.8.2",
    "typescript": "^5.3.0"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  }
}
