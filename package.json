{
  "name": "runtime-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Deploy any Python FastAPI app to the cloud in 30 seconds. Zero Docker, zero config. Self-hostable serverless platform with GPU support, auto-generated UIs, and built-in secrets management.",
  "keywords": [
    "fastapi",
    "python",
    "serverless",
    "deployment",
    "api",
    "modal",
    "gpu",
    "machine-learning",
    "ml-deployment",
    "paas",
    "self-hosted",
    "open-source",
    "cloud",
    "backend",
    "infrastructure",
    "devops",
    "secrets-management",
    "openapi",
    "swagger"
  ],
  "homepage": "https://github.com/federicodeponte/runtime-ai#readme",
  "bugs": {
    "url": "https://github.com/federicodeponte/runtime-ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/federicodeponte/runtime-ai.git"
  },
  "license": "MIT",
  "author": "Runtime AI Contributors",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "align:vitest-provider": "node ./infra/scripts/align-vitest-provider-version.mjs",
    "verify:ts-coverage": "npm run align:vitest-provider && node ./infra/scripts/verify-ts-coverage.mjs",
    "verify:runner": "cd services/runner && pytest tests/ -q --cov=src --cov-report=term-missing --cov-fail-under=77",
    "verify:sdk": "cd services/runner/sdk && PYTHONPATH=. pytest tests/ -q --cov=execution_layer --cov-report=term-missing --cov-fail-under=77",
    "verify": "npm run lint && npm test && npm run build && npm run verify:ts-coverage && npm run verify:runner && npm run verify:sdk",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "cleanup": "tsx infra/scripts/retention-cleanup.ts",
    "cleanup:dry-run": "tsx infra/scripts/retention-cleanup.ts --dry-run"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@next/eslint-plugin-next": "^16.1.6",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.1.0",
    "turbo": "^2.8.2",
    "typescript": "^5.3.0"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  }
}
