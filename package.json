{
  "name": "runit",
  "version": "0.1.0",
  "private": true,
  "description": "AI writes code. RunIt makes it real.",
  "keywords": [
    "python",
    "deployment",
    "ai",
    "chatgpt",
    "web-app",
    "no-code",
    "low-code",
    "self-hosted",
    "open-source",
    "serverless",
    "api",
    "auto-ui"
  ],
  "homepage": "https://github.com/buildingopen/runit#readme",
  "bugs": {
    "url": "https://github.com/buildingopen/runit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/buildingopen/runit.git"
  },
  "license": "MIT",
  "author": "BuildingOpen",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "align:vitest-provider": "node ./infra/scripts/align-vitest-provider-version.mjs",
    "verify:ts-coverage": "npm run align:vitest-provider && node ./infra/scripts/verify-ts-coverage.mjs",
    "verify:runner": "cd services/runner && pytest tests/ -q --cov=src --cov-report=term-missing --cov-fail-under=77",
    "verify:sdk": "cd services/runner/sdk && PYTHONPATH=. pytest tests/ -q --cov=runit --cov-report=term-missing --cov-fail-under=77",
    "verify": "npm run lint && npm test && npm run build && npm run verify:ts-coverage && npm run verify:runner && npm run verify:sdk",
    "smoke:golden": "./infra/scripts/smoke-golden-path.sh",
    "setup:local": "./infra/scripts/setup-local.sh",
    "dev:local": "NEXT_PUBLIC_API_URL=http://localhost:3001 npm run dev --workspace=apps/web -- -p 3000",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "cleanup": "tsx infra/scripts/retention-cleanup.ts",
    "cleanup:dry-run": "tsx infra/scripts/retention-cleanup.ts --dry-run"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@next/eslint-plugin-next": "^16.1.6",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.1.0",
    "turbo": "^2.8.2",
    "typescript": "^5.3.0"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  }
}
