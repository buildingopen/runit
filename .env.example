# RunIt Environment Configuration
# Copy to .env and fill in values
#
# For self-hosted (Docker): only MASTER_ENCRYPTION_KEY is required.
# For cloud mode: also set Supabase, Modal, and Stripe vars.

# ============================================
# Required
# ============================================

# Encryption key for secrets vault (REQUIRED)
# Generate with: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=

# ============================================
# Compute Backend
# ============================================
# "docker" for self-hosted, "modal" for Modal cloud
COMPUTE_BACKEND=docker

# Deployment mode: "oss" (default, self-hosted) or "cloud"
# RUNIT_MODE=oss

# Runner container settings
# RUNNER_IMAGE=runit-runner:latest
# RUNNER_MEMORY=512m
# RUNNER_CPUS=1
# RUNNER_NETWORK=none

# Data directory for SQLite and storage (inside the container)
# RUNIT_DATA_DIR=/data

# Host-visible path for runner workspace volumes (Docker-in-Docker)
# RUNNER_WORKSPACE_DIR=/tmp/runit-workspaces

# Host-visible path for runner storage volumes (Docker-in-Docker)
# RUNNER_STORAGE_BASE_DIR=/tmp/runit-storage

# ============================================
# Server
# ============================================
PORT=3001
NODE_ENV=production

# ============================================
# API Security (optional)
# ============================================
# Bearer token to protect API endpoints
# API_KEY=

# Comma-separated allowed CORS origins
# CORS_ORIGINS=http://localhost:3000

# ============================================
# Tunnel (optional, for public URL)
# ============================================
# TUNNEL_URL=https://your-tunnel.trycloudflare.com
# TUNNEL_TOKEN=

# ============================================
# Cloud Mode (optional, skip for self-hosted)
# ============================================
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
# STREAM_TOKEN_SECRET=
# METRICS_TOKEN=
# SENTRY_DSN=
# REDIS_URL=redis://localhost:6379

# Stripe billing
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_TEAM_PRICE_ID=price_...
# FRONTEND_URL=http://localhost:3000

# Web frontend (public keys)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_API_URL=http://localhost:3001
