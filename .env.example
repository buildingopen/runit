# Execution Layer Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# Supabase Configuration
# ============================================

# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web frontend (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ============================================
# Encryption
# ============================================

# Master encryption key for secrets
# Generate with: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=your-32-byte-base64-encoded-key

# ============================================
# Modal Configuration
# ============================================

# Get these from modal.com dashboard
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret

# ============================================
# API Configuration
# ============================================

# Control plane API URL (for web frontend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Control plane port
PORT=3001

# ============================================
# Development
# ============================================

# Enable development mode (bypasses auth in control-plane)
DEV_MODE=true

# Node environment
NODE_ENV=development

# ============================================
# Optional: AWS (for production secrets storage)
# ============================================

# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# KMS_KEY_ID=your-kms-key-id

# ============================================
# Optional: Production URLs
# ============================================

# NEXT_PUBLIC_API_URL=https://api.executionlayer.com
# CORS_ORIGINS=https://executionlayer.com,https://www.executionlayer.com
