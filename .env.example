# Runtime Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# Supabase Configuration (Required in Production)
# ============================================

# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web frontend (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ============================================
# Encryption (Required in Production)
# ============================================

# Master encryption key for secrets (REQUIRED)
# Generate with: openssl rand -base64 32
# MUST be exactly 32 bytes when decoded
MASTER_ENCRYPTION_KEY=your-32-byte-base64-encoded-key

# ============================================
# Error Tracking (Required in Production)
# ============================================

# Sentry DSN for error tracking (REQUIRED in production)
# Get this from sentry.io project settings
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# ============================================
# CORS Configuration (Required in Production)
# ============================================

# Comma-separated list of allowed origins (REQUIRED in production)
# Must be valid URLs
CORS_ORIGINS=https://your-frontend.onrender.com,https://your-app.com

# ============================================
# Modal Configuration
# ============================================

# Get these from modal.com dashboard
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret

# ============================================
# API Configuration
# ============================================

# Control plane API URL (for web frontend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Control plane port
PORT=3001

# ============================================
# Redis (Optional - for distributed rate limiting)
# ============================================

# Redis URL for distributed rate limiting across multiple instances
# If not set, falls back to DB-backed or in-memory rate limiting
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://user:password@your-redis.upstash.io:6379

# ============================================
# Development
# ============================================

# Enable development mode (bypasses auth when Supabase is not configured)
DEV_MODE=true

# Node environment
NODE_ENV=development

# Disable rate limiting in development
# DISABLE_RATE_LIMIT=true

# ============================================
# Optional: AWS (for production secrets storage)
# ============================================

# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# KMS_KEY_ID=your-kms-key-id

# ============================================
# OpenTelemetry Tracing (Optional)
# ============================================

# OTLP endpoint for trace export (e.g., Jaeger, Zipkin, Grafana Tempo)
# If not set, uses console exporter in development, disabled in production
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Optional headers for OTLP exporter (JSON format)
# Useful for authentication with hosted tracing services
# OTEL_EXPORTER_OTLP_HEADERS={"Authorization":"Bearer your-token"}

# Disable tracing entirely (default: tracing is enabled)
# OTEL_TRACING_ENABLED=false

# ============================================
# E2E Testing (Optional - for running E2E tests)
# ============================================

# Separate Supabase instance for E2E tests
# This should be a dedicated test project to avoid data conflicts
# E2E tests are skipped if these variables are not set

# SUPABASE_URL_TEST=https://your-test-project.supabase.co
# SUPABASE_ANON_KEY_TEST=your-test-anon-key
# SUPABASE_SERVICE_ROLE_KEY_TEST=your-test-service-role-key
