# RunIt Environment Configuration
# Copy to .env and fill in values
#
# For self-hosted (Docker): only MASTER_ENCRYPTION_KEY is required.
# For cloud mode (runit-cloud): see runit-cloud/.env.example.

# ============================================
# Required
# ============================================

# Encryption key for secrets vault (REQUIRED)
# Generate with: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=

# ============================================
# Compute Backend
# ============================================
# "docker" for self-hosted (default)
COMPUTE_BACKEND=docker

# Deployment mode: "oss" (default, self-hosted) or "cloud"
# RUNIT_MODE=oss

# Runner container settings
# RUNNER_IMAGE=runit-runner:latest
# RUNNER_MEMORY=512m
# RUNNER_CPUS=1
# RUNNER_NETWORK=none

# Data directory for SQLite and storage (inside the container)
# RUNIT_DATA_DIR=/data

# Host-visible path for runner workspace volumes (Docker-in-Docker)
# RUNNER_WORKSPACE_DIR=/tmp/runit-workspaces

# Host-visible path for runner storage volumes (Docker-in-Docker)
# RUNNER_STORAGE_BASE_DIR=/tmp/runit-storage

# ============================================
# Server
# ============================================
PORT=3001
NODE_ENV=production

# ============================================
# API Security (optional)
# ============================================
# Bearer token to protect API endpoints
# API_KEY=

# Comma-separated allowed CORS origins
# CORS_ORIGINS=http://localhost:3000

# ============================================
# Tunnel (optional, for public URL)
# ============================================
# TUNNEL_URL=https://your-tunnel.trycloudflare.com
# TUNNEL_TOKEN=

# ============================================
# Web frontend (optional)
# ============================================
# NEXT_PUBLIC_API_URL=http://localhost:3001
