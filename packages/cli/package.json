{
  "name": "@runit/cli",
  "version": "0.1.0",
  "description": "CLI for RunIt - deploy Python code from the terminal",
  "type": "module",
  "bin": {
    "runit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest --run"
  },
  "dependencies": {
    "@runit/client": "*",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "runit",
    "cli",
    "deploy",
    "python"
  ],
  "license": "MIT"
}
