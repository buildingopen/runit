{
  "name": "@buildingopen/cli",
  "version": "0.1.0",
  "description": "Deploy Python functions as live web apps",
  "type": "module",
  "bin": {
    "runit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest --run"
  },
  "dependencies": {
    "@buildingopen/client": "0.1.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "runit",
    "cli",
    "deploy",
    "python"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/buildingopen/runit",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/buildingopen/runit#readme",
  "publishConfig": {
    "access": "public"
  }
}
