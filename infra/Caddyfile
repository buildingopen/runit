{$API_DOMAIN:api.runit.dev} {
    reverse_proxy localhost:3001

    header {
        -Server
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
    }

    log {
        output file /var/log/caddy/runit-api.log
        format filter {
            wrap json
            fields {
                request>uri query {
                    replace token REDACTED
                }
            }
        }
    }
}
