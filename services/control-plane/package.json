{
  "name": "@buildingopen/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "test": "NODE_ENV=test OTEL_TRACING_ENABLED=false vitest --run --config vitest.config.ts",
    "test:e2e": "NODE_ENV=test OTEL_TRACING_ENABLED=false vitest --run --config vitest.config.e2e.ts",
    "test:e2e:ci": "NODE_ENV=test OTEL_TRACING_ENABLED=false vitest --run --config vitest.config.e2e.ts --reporter=verbose --no-color",
    "lint": "tsc --noEmit",
    "test:load": "k6 run tests/load/k6-config.js --env SCENARIO=smoke",
    "test:load:smoke": "k6 run tests/load/k6-config.js --env SCENARIO=smoke",
    "test:load:scenario": "k6 run tests/load/k6-config.js --env SCENARIO=load",
    "test:load:stress": "k6 run tests/load/k6-config.js --env SCENARIO=stress",
    "test:load:spike": "k6 run tests/load/k6-config.js --env SCENARIO=spike",
    "test:load:health": "k6 run tests/load/scenarios/health-check.js",
    "test:load:projects": "k6 run tests/load/scenarios/create-project.js",
    "test:load:secrets": "k6 run tests/load/scenarios/secrets-crud.js",
    "test:load:mixed": "k6 run tests/load/scenarios/mixed-workload.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.4.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@buildingopen/shared": "*",
    "@sentry/node": "^10.38.0",
    "@supabase/supabase-js": "^2.38.0",
    "@types/opossum": "^8.1.9",
    "adm-zip": "^0.5.10",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^17.2.3",
    "hono": "^4.11.8",
    "jose": "^5.1.0",
    "js-yaml": "^4.1.0",
    "opossum": "^8.5.0",
    "prom-client": "^15.1.3",
    "uuid": "^9.0.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@aws-sdk/client-kms": "^3.500.0",
    "ioredis": "^5.9.2",
    "stripe": "^20.3.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.8",
    "eslint": "^8.55.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
